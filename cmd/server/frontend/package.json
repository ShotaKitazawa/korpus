{
  "name": "korpus-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && touch dist/.gitkeep",
    "dev": "vite",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "openapi-ts": "openapi-typescript ../../../openapi.yaml -o src/gen/api.d.ts",
    "sync:pin": "node ../../scripts/sync-frontend.ts --pin"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.0",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@11.6.0"
}
