{
  "name": "korpus-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "build": "vite build && touch dist/.gitkeep",
    "dev": "vite",
    "lint": "oxlint .",
    "format": "oxfmt -w .",
    "format:check": "oxfmt .",
    "test": "vitest run",
    "openapi-ts": "openapi-typescript ../../../openapi.yaml -o src/gen/api.d.ts",
    "sync:pin": "node ../../scripts/sync-frontend.ts --pin"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.1.0",
    "oxlint": "^1.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.2"
  }
}
